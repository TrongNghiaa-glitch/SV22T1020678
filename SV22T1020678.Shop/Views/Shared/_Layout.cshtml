<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TNP Shop</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        body {
            background-color: #f4f6f9;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .navbar {
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        }

        .main-content {
            flex: 1;
            padding: 30px 0;
        }

        .footer {
            background-color: #212529;
            color: #adb5bd;
            padding: 20px 0;
        }

        .card-product:hover {
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            transform: translateY(-2px);
            transition: all 0.3s;
        }

        .dropdown-item i {
            margin-right: 8px;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold text-primary fs-4" href="~/">
                <i class="bi bi-shop"></i> TNP Shop
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarShop">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarShop">

                <div class="mx-auto text-center d-none d-lg-block">
                    <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2 me-2 border border-primary">
                        <i class="bi bi-truck fs-6 me-1"></i> Freeship từ 500k
                    </span>
                    <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-3 py-2 me-2 border border-danger">
                        <i class="bi bi-shield-check fs-6 me-1"></i> Chính hãng 100%
                    </span>
                    <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2 border border-success">
                        <i class="bi bi-arrow-repeat fs-6 me-1"></i> Đổi trả 7 ngày
                    </span>
                </div>

                <ul class="navbar-nav ms-auto align-items-center">

                    <li class="nav-item me-4">
                        <a href="~/Cart" class="btn btn-outline-primary rounded-pill px-4 fw-bold shadow-sm">
                            <i class="bi bi-cart3 fs-5 me-1"></i> Giỏ hàng
                        </a>
                    </li>

                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark fw-bold" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle me-1"></i> Chào, @User.Identity.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                                <li>
                                    <a class="dropdown-item" href="~/Account/Profile">
                                        <i class="bi bi-person-lines-fill"></i> Thông tin cá nhân
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="~/Order/History">
                                        <i class="bi bi-clock-history"></i> Lịch sử mua hàng
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item text-danger" href="~/Account/Logout">
                                        <i class="bi bi-box-arrow-right"></i> Đăng xuất
                                    </a>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-bold btn btn-light rounded-pill px-4 shadow-sm" href="~/Account/Login">
                                <i class="bi bi-person-circle"></i> Đăng nhập
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main role="main" class="main-content">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <footer class="footer text-center mt-auto">
        <div class="container">
            <p class="mb-1 fw-bold">&copy; 2026 - TNP Shop</p>
            <div class="text-muted small">
                <i class="bi bi-telephone"></i> Hotline: 1900 6789 | <i class="bi bi-envelope"></i> Email: hotro@tnpshop.com
            </div>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>