@using System.Security.Claims
@{
    var userName = User.Identity.IsAuthenticated ? (User.FindFirst("FullName")?.Value ?? User.Identity.Name) : "Tài khoản";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>@ViewData["Title"] - Electro Shop</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;500;600;700&family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://use.fontawesome.com/releases/v5.15.4/css/all.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <link href="~/lib/animate/animate.min.css" rel="stylesheet">
    <link href="~/lib/owlcarousel/assets/owl.carousel.min.css" rel="stylesheet">
    <link href="~/lib/lightbox/css/lightbox.min.css" rel="stylesheet">
    <link href="~/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/css/style.css" rel="stylesheet">
    <style>
        .sticky-cart-container { position: fixed !important; right: 30px !important; bottom: 30px !important; z-index: 999999 !important; }
        .sticky-cart-btn { width: 70px; height: 70px; background-color: #ffb524; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 8px 20px rgba(0,0,0,0.4); border: 4px solid #ffffff; text-decoration: none; position: relative; }
        #cart-count-badge { position: absolute; top: -2px; right: -2px; background-color: #ff0000; color: #ffffff; border-radius: 50%; width: 26px; height: 26px; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: bold; border: 2px solid #ffffff; }
        .flying-img { position: absolute !important; z-index: 1000000 !important; width: 100px; height: 100px; object-fit: cover; border-radius: 50%; box-shadow: 0 5px 15px rgba(0,0,0,0.3); pointer-events: none; }
    </style>
</head>
<body>
    <div class="sticky-cart-container animate__animated animate__fadeInRight">
        <a href="~/Cart" class="sticky-cart-btn" id="main-cart-icon">
            <i class="fas fa-shopping-cart" style="color: white; font-size: 30px;"></i>
            <span id="cart-count-badge">0</span>
        </a>
    </div>

    <div class="container-fluid px-5 d-none d-lg-block border-bottom bg-white py-2">
        <div class="row gx-0 align-items-center">
            <div class="col-lg-8 small text-muted">Help / Support / Contact | Call Us: (+012) 1234 567890</div>
            <div class="col-lg-4 text-end">
                <div class="dropdown">
                    <a href="#" class="dropdown-toggle text-dark fw-bold small" data-bs-toggle="dropdown">
                        <i class="fa fa-user me-2 text-primary"></i> @userName
                    </a>
                    <div class="dropdown-menu dropdown-menu-end shadow border-0">
                        @if (User.Identity.IsAuthenticated) {
                            <a href="~/Account/Profile" class="dropdown-item">Thông tin</a>
                            <a href="~/Order/History" class="dropdown-item">Lịch sử đơn hàng</a>
                            <hr class="dropdown-divider">
                            <a href="~/Account/Logout" class="dropdown-item text-danger">Đăng xuất</a>
                        } else {
                            <a href="~/Account/Login" class="dropdown-item">Đăng nhập</a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="container-fluid px-5 py-4 bg-white">
        <div class="row align-items-center">
            <div class="col-lg-3"><a href="~/" class="navbar-brand p-0"><h1 class="text-primary m-0"><i class="fas fa-shopping-bag text-secondary me-2"></i>Electro</h1></a></div>
            <div class="col-lg-6">
                <form id="headerSearchForm" action="~/" method="get" class="d-flex border rounded-pill overflow-hidden shadow-sm">
                    <input class="form-control border-0 px-4 py-2" name="searchValue" type="text" placeholder="Bạn muốn tìm gì hôm nay?">
                    <button class="btn btn-primary px-4"><i class="fas fa-search"></i></button>
                </form>
            </div>
            <div class="col-lg-3 text-end d-flex justify-content-end align-items-center gap-3">
                <i class="fa fa-heart text-primary fs-5"></i>
                <a href="~/Cart" class="text-dark fw-bold text-decoration-none"><i class="fa fa-shopping-cart text-primary me-1"></i> Giỏ hàng</a>
            </div>
        </div>
    </div>

    @RenderBody()

    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.4/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/wow/wow.min.js"></script>
    <script src="~/lib/easing/easing.min.js"></script>
    <script src="~/lib/owlcarousel/owl.carousel.min.js"></script>
    <script src="~/lib/lightbox/js/lightbox.min.js"></script>
    <script src="~/js/main.js"></script>
    <script>
        $(document).ready(function () {
            // ... các code cũ của cậu (giỏ hàng bay, v.v.) ...

            // 🚀 Xử lý nhảy xuống sản phẩm khi tìm kiếm ở Header
            $("#headerSearchForm").submit(function() {
                // Lấy action hiện tại (thường là /) và nối thêm cái mỏ neo #product-list-section
                // .split('#')[0] để đảm bảo không bị lặp lại dấu # nếu người dùng search nhiều lần
                this.action = this.action.split('#')[0] + "#product-list-section";
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>