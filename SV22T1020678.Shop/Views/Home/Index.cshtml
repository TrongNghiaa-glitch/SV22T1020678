@model SV22T1020678.Models.Common.PagedResult<SV22T1020678.Models.Catalog.Product>
@{
    ViewData["Title"] = "Trang chủ";
    var searchInput = ViewBag.SearchInput as SV22T1020678.Models.Catalog.ProductSearchInput;
}

<div class="card shadow-sm border-0 mb-4 p-3 rounded-4 bg-light">
    <form action="~/" method="get">
        <div class="row g-2 align-items-center">
            <div class="col-md-2">
                <select class="form-select rounded-pill" name="categoryId">
                    <option value="0">-- Tất cả loại hàng --</option>
                    @if (ViewBag.Categories != null)
                    {
                        foreach (var cat in ViewBag.Categories)
                        {
                            if (cat.CategoryID == searchInput?.CategoryID)
                            {
                                <option value="@cat.CategoryID" selected>@cat.CategoryName</option>
                            }
                            else
                            {
                                <option value="@cat.CategoryID">@cat.CategoryName</option>
                            }
                        }
                    }
                </select>
            </div>
            <div class="col-md-2">
                <input type="text" name="searchValue" value="@searchInput?.SearchValue" class="form-control rounded-pill" placeholder="Tên sản phẩm...">
            </div>
            <div class="col-md-2">
                <input type="number" name="minPrice" value="@(searchInput?.MinPrice == 0 ? "" : searchInput?.MinPrice)" class="form-control rounded-pill" placeholder="Giá từ...">
            </div>
            <div class="col-md-2">
                <input type="number" name="maxPrice" value="@(searchInput?.MaxPrice == 0 ? "" : searchInput?.MaxPrice)" class="form-control rounded-pill" placeholder="Đến giá...">
            </div>

            <div class="col-md-2">
                <select class="form-select rounded-pill" name="sortOrder" onchange="this.form.submit()">
                    @if (string.IsNullOrEmpty(searchInput?.SortOrder) || searchInput?.SortOrder == "NameASC")
                    {
                        <option value="NameASC" selected>Tên A-Z</option>
                    }
                    else
                    {
                        <option value="NameASC">Tên A-Z</option>
                    }

                    @if (searchInput?.SortOrder == "NameDESC")
                    {
                        <option value="NameDESC" selected>Tên Z-A</option>
                    }
                    else
                    {
                        <option value="NameDESC">Tên Z-A</option>
                    }

                    @if (searchInput?.SortOrder == "PriceASC")
                    {
                        <option value="PriceASC" selected>Giá tăng dần</option>
                    }
                    else
                    {
                        <option value="PriceASC">Giá tăng dần</option>
                    }

                    @if (searchInput?.SortOrder == "PriceDESC")
                    {
                        <option value="PriceDESC" selected>Giá giảm dần</option>
                    }
                    else
                    {
                        <option value="PriceDESC">Giá giảm dần</option>
                    }
                </select>
            </div>

            <div class="col-md-2">
                <button type="submit" class="btn btn-primary rounded-pill w-100 fw-bold"><i class="bi bi-search"></i> Tìm kiếm</button>
            </div>
        </div>
    </form>
</div>

<div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
    @foreach (var item in Model.DataItems)
    {
        <div class="col">
            <div class="card h-100 shadow-sm border-0 product-card rounded-4 overflow-hidden">
                <a href="~/Home/Details/@item.ProductID">
                    <img src="http://localhost:5258/images/products/@(string.IsNullOrEmpty(item.Photo) ? "nophoto.png" : item.Photo)" class="card-img-top" alt="@item.ProductName" style="height: 200px; object-fit: cover;">
                </a>
                <div class="card-body d-flex flex-column">
                    <h6 class="card-title fw-bold">
                        <a href="~/Home/Details/@item.ProductID" class="text-dark text-decoration-none">@item.ProductName</a>
                    </h6>
                    <p class="text-danger fw-bold fs-5 mb-3 mt-auto">@item.Price.ToString("N0") đ</p>

                    <form action="~/Cart/Add" method="post" class="mt-auto">
                        <input type="hidden" name="productId" value="@item.ProductID" />
                        <input type="hidden" name="productName" value="@item.ProductName" />
                        <input type="hidden" name="salePrice" value="@item.Price" />
                        <button type="submit" class="btn btn-outline-primary w-100 rounded-pill"><i class="bi bi-cart-plus"></i> Chọn mua</button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>

@if (Model.PageCount > 1)
{
    <style>
        .pagination-circular .page-item {
            margin: 0 4px;
        }

        .pagination-circular .page-link {
            border-radius: 50% !important; /* Bo tròn tuyệt đối */
            width: 45px;
            height: 45px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 500;
            color: #495057;
            border: 1px solid #dee2e6;
            transition: all 0.2s;
        }

        .pagination-circular .page-item.active .page-link {
            background-color: #0d6efd;
            border-color: #0d6efd;
            color: #fff;
            box-shadow: 0 3px 6px rgba(13,110,253,0.3);
        }

        .pagination-circular .page-link:hover:not(.active) {
            background-color: #e9ecef;
        }

        .pagination-circular .page-item.disabled .page-link {
            opacity: 0.5;
            cursor: not-allowed;
        }
    </style>

    int currentPage = Model.Page;
    int totalPages = Model.PageCount;
    int maxPagesToShow = 5;

    int startPage = Math.Max(1, currentPage - maxPagesToShow / 2);
    int endPage = Math.Min(totalPages, currentPage + maxPagesToShow / 2);

    if (startPage == 1) { endPage = Math.Min(totalPages, maxPagesToShow); }
    if (endPage == totalPages) { startPage = Math.Max(1, totalPages - maxPagesToShow + 1); }

    <div class="d-flex justify-content-center mt-5 mb-5">
        <ul class="pagination pagination-circular shadow-sm">

            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link" href="~/?categoryId=@searchInput?.CategoryID&supplierId=@searchInput?.SupplierID&minPrice=@(searchInput?.MinPrice == 0 ? "" : searchInput?.MinPrice)&maxPrice=@(searchInput?.MaxPrice == 0 ? "" : searchInput?.MaxPrice)&searchValue=@searchInput?.SearchValue&sortOrder=@searchInput?.SortOrder&page=1" title="Trang đầu">
                    &lt;&lt;
                </a>
            </li>

            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link" href="~/?categoryId=@searchInput?.CategoryID&supplierId=@searchInput?.SupplierID&minPrice=@(searchInput?.MinPrice == 0 ? "" : searchInput?.MinPrice)&maxPrice=@(searchInput?.MaxPrice == 0 ? "" : searchInput?.MaxPrice)&searchValue=@searchInput?.SearchValue&sortOrder=@searchInput?.SortOrder&page=@(currentPage - 1)" title="Trang trước">
                    &lt;
                </a>
            </li>

            @for (int i = startPage; i <= endPage; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" href="~/?categoryId=@searchInput?.CategoryID&supplierId=@searchInput?.SupplierID&minPrice=@(searchInput?.MinPrice == 0 ? "" : searchInput?.MinPrice)&maxPrice=@(searchInput?.MaxPrice == 0 ? "" : searchInput?.MaxPrice)&searchValue=@searchInput?.SearchValue&sortOrder=@searchInput?.SortOrder&page=@i">
                        @i
                    </a>
                </li>
            }

            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link" href="~/?categoryId=@searchInput?.CategoryID&supplierId=@searchInput?.SupplierID&minPrice=@(searchInput?.MinPrice == 0 ? "" : searchInput?.MinPrice)&maxPrice=@(searchInput?.MaxPrice == 0 ? "" : searchInput?.MaxPrice)&searchValue=@searchInput?.SearchValue&sortOrder=@searchInput?.SortOrder&page=@(currentPage + 1)" title="Trang sau">
                    &gt;
                </a>
            </li>

            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link" href="~/?categoryId=@searchInput?.CategoryID&supplierId=@searchInput?.SupplierID&minPrice=@(searchInput?.MinPrice == 0 ? "" : searchInput?.MinPrice)&maxPrice=@(searchInput?.MaxPrice == 0 ? "" : searchInput?.MaxPrice)&searchValue=@searchInput?.SearchValue&sortOrder=@searchInput?.SortOrder&page=@totalPages" title="Trang cuối">
                    &gt;&gt;
                </a>
            </li>

        </ul>
    </div>
}