@model IEnumerable<SV22T1020678.Models.Sales.CartItem>
@{
    ViewData["Title"] = "Thanh toán";
}

<div class="row mt-4">
    <div class="col-md-7">
        <div class="card shadow-sm border-0 rounded-3 mb-4">
            <div class="card-header bg-white fw-bold py-3">
                <i class="bi bi-geo-alt-fill text-danger me-1"></i> Thông tin giao hàng
            </div>
            <div class="card-body">
                <form id="frmCheckout">
                    @* 1. THÊM TOKEN BẢO MẬT ĐỂ KHÔNG BỊ LỖI ĐƠ *@
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Tỉnh/Thành phố <span class="text-danger">*</span></label>
                        <input type="text" name="deliveryProvince" class="form-control" placeholder="Nhập Tỉnh/Thành phố..." required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Địa chỉ nhận hàng cụ thể <span class="text-danger">*</span></label>
                        <textarea name="deliveryAddress" class="form-control" rows="3" placeholder="Số nhà, Tên đường, Phường/Xã..." required></textarea>
                    </div>
                    <button type="submit" class="btn btn-danger w-100 py-3 fw-bold rounded-3 shadow-sm">
                        XÁC NHẬN ĐẶT HÀNG
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-5">
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-header bg-white fw-bold py-3">
                <i class="bi bi-cart-check-fill text-success me-1"></i> Tóm tắt đơn hàng
            </div>
            <div class="card-body">
                <div class="order-items-scroll" style="max-height: 400px; overflow-y: auto;">
                    @foreach (var item in Model)
                    {
                        <div class="d-flex justify-content-between mb-3 align-items-center">
                            <div style="flex: 1;">
                                <div class="fw-bold small text-truncate" style="max-width: 200px;">@item.ProductName</div>
                                <div class="text-muted small">Số lượng: @item.Quantity</div>
                            </div>
                            <div class="text-end fw-semibold">
                                @item.TotalPrice.ToString("N0") <span class="small">đ</span>
                            </div>
                        </div>
                    }
                </div>
                <hr class="my-3">
                <div class="d-flex justify-content-between align-items-center fw-bold fs-5 text-danger">
                    <span>TỔNG CỘNG:</span>
                    <span>@Model.Sum(x => x.TotalPrice).ToString("N0") đ</span>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @* NHÚNG THƯ VIỆN THÔNG BÁO XỊN *@
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
            $("#frmCheckout").submit(function (e) {
                e.preventDefault();

                var form = $(this);

                // HIỆN LOADING KHI ĐANG XỬ LÝ
                Swal.fire({
                    title: 'Đang xử lý...',
                    text: 'Vui lòng chờ trong giây lát',
                    allowOutsideClick: false,
                    didOpen: () => { Swal.showLoading(); }
                });

                $.ajax({
                    url: '@Url.Action("Init", "Order")', // Tự lấy URL chuẩn
                    type: 'POST',
                    data: form.serialize(),
                    success: function (res) {
                        if (res.success) {
                            // 2. CHỐT HÀM NHẢY TRANG KHI THÀNH CÔNG
                            Swal.fire({
                                title: 'Đặt hàng thành công!',
                                text: 'Hệ thống đang chuyển bạn đến lịch sử mua hàng...',
                                icon: 'success',
                                timer: 2000,
                                showConfirmButton: false
                            }).then(() => {
                                // BAY THẲNG VỀ TRANG LỊCH SỬ, KHÔNG Ở LẠI ĐỂ ROLL UP
                                window.location.href = "@Url.Action("History", "Order")";
                            });
                        } else {
                            Swal.fire('Thông báo', res.message, 'warning');
                        }
                    },
                    error: function (xhr) {
                        console.error(xhr.responseText);
                        Swal.fire('Lỗi hệ thống', 'Không thể kết nối đến máy chủ (Mã: ' + xhr.status + ')', 'error');
                    }
                });
            });
        });
    </script>
}