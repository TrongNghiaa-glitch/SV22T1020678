@model IEnumerable<SV22T1020678.Models.Sales.Order>
@{
    ViewData["Title"] = "Lịch sử mua hàng";
    Layout = "_Layout";
}

<div class="container mt-5 mb-5">
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-header bg-primary text-white rounded-top-4 p-3 d-flex justify-content-between align-items-center">
            <h4 class="mb-0 fw-bold"><i class="bi bi-clock-history"></i> LỊCH SỬ ĐƠN HÀNG CỦA BẠN</h4>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="px-4 py-3">Mã đơn</th>
                            <th>Ngày đặt hàng</th>
                            <th>Thông tin nhận hàng</th>
                            <th>Tiến trình xử lý</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="px-4 fw-bold text-primary fs-5">#@item.OrderID</td>
                                    <td>
                                        <i class="bi bi-calendar-check text-muted"></i> @item.OrderTime.ToString("dd/MM/yyyy HH:mm")
                                    </td>
                                    <td>
                                        <div class="fw-bold">@item.DeliveryProvince</div>
                                        <small class="text-muted">@item.DeliveryAddress</small>
                                    </td>
                                    <td>
                                        @if ((int)item.Status == 1)
                                        {
                                            <span class="badge bg-secondary mb-1 px-3 py-2">Chờ duyệt</span>
                                
                                            <br />
                                            <small class="text-muted fst-italic">Vừa lên đơn</small>
                                        }
                                        else if ((int)item.Status == 2)
                                        {
                                            <span class="badge bg-info text-dark mb-1 px-3 py-2">Đã duyệt</span>
                                
                                            <br />
                                            <small class="text-success fw-bold"><i class="bi bi-check-circle"></i> Đang chờ lấy hàng</small>
                                        }
                                        else if ((int)item.Status == 3)
                                        {
                                            <span class="badge bg-warning text-dark mb-1 px-3 py-2">Đang giao hàng</span>
                                
                                            <br />
                                            <small class="text-primary fw-bold"><i class="bi bi-truck"></i> Shipper đang trên đường</small>
                                        }
                                        else if ((int)item.Status == 4)
                                        {
                                            <span class="badge bg-success mb-1 px-3 py-2">Hoàn tất</span>
                                
                                            <br />
                                            <small class="text-success"><i class="bi bi-house-check"></i> Đã giao thành công</small>
                                        }
                                        else if ((int)item.Status == -1 || (int)item.Status == -2)
                                        {
                                            <span class="badge bg-danger mb-1 px-3 py-2">Đã hủy / Từ chối</span>
                                
                                            <br />
                                            <small class="text-danger"><i class="bi bi-x-circle"></i> Đơn hàng không thành công</small>
                                        }
                                        else
                                        {
                                            <span class="badge bg-dark px-3 py-2">Không xác định</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted fs-5">
                                    <img src="https://cdn-icons-png.flaticon.com/512/11329/11329060.png" alt="Empty Cart" style="width: 100px; opacity: 0.5" class="mb-3" />
                                    <span class="d-block">Bạn chưa có đơn hàng nào. Hãy mua sắm thêm nhé!</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>