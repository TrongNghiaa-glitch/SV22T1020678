@* Views/Account/ChangePassword.cshtml *@
@{
    ViewBag.Title = "Đổi mật khẩu - ELECTRO Admin";
}

<div class="row justify-content-center pt-5">
    <div class="col-md-6 col-lg-5">
        <form action="~/Account/ChangePassword" method="post">
            @* QUAN TRỌNG: Mã bảo mật để không bị văng ra trang Login *@
            @Html.AntiForgeryToken()

            <div class="card card-outline card-warning shadow-lg border-0">
                <div class="card-header bg-white py-3">
                    <h3 class="card-title fw-bold text-warning mb-0">
                        <i class="bi bi-shield-lock-fill me-2"></i>BẢO MẬT HỆ THỐNG
                    </h3>
                </div>

                <div class="card-body p-4">

                    @* --- HIỂN THỊ LỖI --- *@
                    @if (!string.IsNullOrEmpty(ViewBag.Error))
                    {
                        <div class="alert alert-danger py-2 border-0 shadow-sm animate__animated animate__shakeX">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.Error
                        </div>
                    }

                    @* --- HIỂN THỊ THÀNH CÔNG --- *@
                    @if (!string.IsNullOrEmpty(ViewBag.Success))
                    {
                        <div class="alert alert-success py-2 border-0 shadow-sm animate__animated animate__fadeInDown">
                            <i class="bi bi-check-circle-fill me-2"></i> @ViewBag.Success
                        </div>
                    }

                    <div class="mb-4">
                        <label class="form-label fw-bold small text-secondary">MẬT KHẨU HIỆN TẠI</label>
                        <div class="input-group border rounded-3 overflow-hidden">
                            <span class="input-group-text bg-light border-0"><i class="bi bi-lock-fill"></i></span>
                            <input type="password" name="oldPassword" class="form-control border-0 shadow-none"
                                   placeholder="Nhập mật khẩu đang dùng" required autofocus>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold small text-secondary">MẬT KHẨU MỚI</label>
                        <div class="input-group border rounded-3 overflow-hidden">
                            <span class="input-group-text bg-light border-0"><i class="bi bi-key-fill"></i></span>
                            <input type="password" name="newPassword" id="newPass" class="form-control border-0 shadow-none"
                                   placeholder="Tối thiểu 3 ký tự" required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold small text-secondary">XÁC NHẬN MẬT KHẨU MỚI</label>
                        <div class="input-group border rounded-3 overflow-hidden">
                            <span class="input-group-text bg-light border-0"><i class="bi bi-check-all"></i></span>
                            <input type="password" name="confirmPassword" id="confirmPass" class="form-control border-0 shadow-none"
                                   placeholder="Nhập lại mật khẩu mới" required>
                        </div>
                    </div>

                    <div class="form-check small mt-2">
                        <input class="form-check-input" type="checkbox" id="showPass" onclick="togglePassword()">
                        <label class="form-check-label text-muted" for="showPass">Hiện mật khẩu</label>
                    </div>
                </div>

                <div class="card-footer bg-white border-top-0 pb-4 px-4">
                    <button type="submit" class="btn btn-warning w-100 fw-bold shadow-sm py-2 text-white rounded-pill">
                        <i class="bi bi-save2-fill me-2"></i>XÁC NHẬN THAY ĐỔI
                    </button>
                    <div class="text-center mt-3">
                        <a href="~/" class="text-decoration-none small text-muted">
                            <i class="bi bi-arrow-left me-1"></i> Quay lại trang chủ
                        </a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@* Script nhỏ để hiện/ẩn mật khẩu cho "Pro" *@
<script>
    function togglePassword() {
        var p1 = document.getElementById("newPass");
        var p2 = document.getElementById("confirmPass");
        if (p1.type === "password") {
            p1.type = "text";
            p2.type = "text";
        } else {
            p1.type = "password";
            p2.type = "password";
        }
    }
</script>