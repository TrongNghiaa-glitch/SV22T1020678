@model SV22T1020678.Models.Common.PagedResult<SV22T1020678.Models.Partner.Customer>
@{
    Layout = null;
}

<div class="mb-2 text-muted">
    Có tất cả <strong>@Model.RowCount</strong> khách hàng trong <strong>@Model.PageCount</strong> trang
</div>

<div class="card">
    <div class="card-body p-1">
        <div class="table-responsive">
            <table class="table table-bordered table-hover mb-0">
                <thead class="table-secondary">
                    <tr>
                        <th>Tên khách hàng</th>
                        <th>Tên giao dịch</th>
                        <th>Điện thoại</th>
                        <th>Email</th>
                        <th>Địa chỉ</th>
                        <th>Tỉnh/Thành</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-center" style="width:130px">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.DataItems == null || Model.DataItems.Count == 0)
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted">Không có dữ liệu</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model.DataItems)
                        {
                            <tr>
                                <td>@item.CustomerName</td>
                                <td>@item.ContactName</td>
                                <td>@item.Phone</td>
                                <td>@item.Email</td>
                                <td>@item.Address</td>
                                <td>@item.Province</td>
                                <td class="text-center">
                                    @if (item.IsLocked==true)
                                    {
                                        <span class="badge bg-danger">Khóa</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Hoạt động</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a href="~/Customer/Edit/@item.CustomerID" class="btn btn-sm btn-primary">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a href="~/Customer/ChangePassword/@item.CustomerID" class="btn btn-sm btn-warning">
                                        <i class="bi bi-key"></i>
                                    </a>
                                    <a href="~/Customer/Delete/@item.CustomerID" class="btn btn-sm btn-danger">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- PAGINATION -->
    @{
        int start = Math.Max(1, Model.Page - 2);
        int end = Math.Min(Model.PageCount, Model.Page + 2);
    }

    @if (Model.PageCount > 1)
    {
        <div class="card-footer">
            <ul class="pagination justify-content-center mb-0">

                <!-- Prev -->
                <li class="page-item @(Model.Page == 1 ? "disabled" : "")">
                    <a class="page-link" href="javascript:;" onclick="doSearch(@(Model.Page - 1))">«</a>
                </li>

                <!-- Pages -->
                @for (int p = start; p <= end; p++)
                {
                    <li class="page-item @(p == Model.Page ? "active" : "")">
                        <a class="page-link" href="javascript:;" onclick="doSearch(@p)">@p</a>
                    </li>
                }

                <!-- Next -->
                <li class="page-item @(Model.Page == Model.PageCount ? "disabled" : "")">
                    <a class="page-link" href="javascript:;" onclick="doSearch(@(Model.Page + 1))">»</a>
                </li>

            </ul>
        </div>
    }
</div>