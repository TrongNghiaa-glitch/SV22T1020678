@model SV22T1020678.Models.Catalog.ProductAttribute
@{
    Layout = null; // Tắt layout cha để vừa khít popup
}

<form action="~/Product/SaveAttribute" method="post">
    <div class="modal-header bg-primary text-white">
        <h5 class="modal-title">
            @(Model.AttributeID == 0 ? "Bổ sung thuộc tính" : "Cập nhật thuộc tính")
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Đóng"></button>
    </div>

    <div class="modal-body">
        <input type="hidden" name="AttributeID" value="@Model.AttributeID" />
        <input type="hidden" name="ProductID" value="@Model.ProductID" />

        <div class="mb-3">
            <label class="form-label fw-bold">Tên thuộc tính</label>
            <input type="text" class="form-control" name="AttributeName" value="@Model.AttributeName" placeholder="VD: Màu sắc, Dung lượng, RAM..." required />
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Giá trị</label>
            <input type="text" class="form-control" name="AttributeValue" value="@Model.AttributeValue" placeholder="VD: Đỏ, 256GB, 8GB..." required />
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Thứ tự hiển thị</label>
            <input type="number" class="form-control" name="DisplayOrder" value="@Model.DisplayOrder" min="1" required />
        </div>
    </div>

    <div class="modal-footer bg-light">
        <button type="submit" class="btn btn-primary fw-bold">
            <i class="bi bi-save"></i> Lưu dữ liệu
        </button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy bỏ</button>
    </div>
</form>