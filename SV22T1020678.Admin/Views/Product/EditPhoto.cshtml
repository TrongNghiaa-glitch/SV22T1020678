@model SV22T1020678.Models.Catalog.ProductPhoto
@{
    // BẮT BUỘC CÓ DÒNG NÀY ĐỂ KHÔNG LOAD MENU TRONG POPUP
    Layout = null;
}

<form id="formEdit" action="~/Product/SavePhoto" method="post" enctype="multipart/form-data">
    @* --- HEADER CỦA POPUP --- *@
    <div class="modal-header bg-primary text-white">
        <h5 class="modal-title" id="photoModalLabel">
            @(Model.PhotoID == 0 ? "Bổ sung ảnh mặt hàng" : "Cập nhật ảnh mặt hàng")
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Đóng"></button>
    </div>

    @* --- BODY CỦA POPUP (Nội dung sếp vừa gửi) --- *@
    <div class="modal-body">
        <input type="hidden" name="PhotoID" value="@Model.PhotoID" />
        <input type="hidden" name="ProductID" value="@Model.ProductID" />
        <input type="hidden" name="Photo" value="@Model.Photo" />

        <div class="row mb-3 align-items-center">
            <label class="col-sm-3 fw-semibold">Ảnh</label>
            <div class="col-sm-9">
                <input type="file" name="uploadPhoto" class="form-control" accept="image/*"
                       onchange="document.getElementById('imgPreview').src = window.URL.createObjectURL(this.files[0])" />
            </div>
        </div>

        <div class="row mb-3">
            <label class="col-sm-3 fw-semibold">Xem trước</label>
            <div class="col-sm-9 text-center border p-2 bg-light rounded">
                <img id="imgPreview" src="~/images/products/@(string.IsNullOrEmpty(Model.Photo) ? "nophoto.png" : Model.Photo)"
                     class="img-thumbnail shadow-sm" style="max-height:160px; object-fit: contain;" />
            </div>
        </div>

        <div class="row mb-3">
            <label class="col-sm-3 fw-semibold">Mô tả</label>
            <div class="col-sm-9">
                <input type="text" name="Description" class="form-control" value="@Model.Description" placeholder="VD: Ảnh mặt trước, Góc trái..." />
            </div>
        </div>

        <div class="row mb-3">
            <label class="col-sm-3 fw-semibold">Thứ tự</label>
            <div class="col-sm-3">
                <input type="number" name="DisplayOrder" class="form-control" value="@Model.DisplayOrder" min="1" />
            </div>
        </div>

        <div class="row mb-2">
            <label class="col-sm-3 fw-semibold">Trạng thái</label>
            <div class="col-sm-9 pt-1">
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" name="IsHidden" id="IsHidden" value="true" @(Model.IsHidden ? "checked" : "") />
                    <label class="form-check-label text-danger" for="IsHidden">Ẩn ảnh này trên Shop</label>
                </div>
            </div>
        </div>
    </div>

    @* --- FOOTER CỦA POPUP (Chứa nút bấm) --- *@
    <div class="modal-footer bg-light">
        <button type="submit" class="btn btn-primary fw-bold">
            <i class="bi bi-save"></i> Lưu dữ liệu
        </button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
            Hủy bỏ
        </button>
    </div>
</form>