@model SV22T1020678.Models.Common.PagedResult<SV22T1020678.Models.Catalog.Product>
@{
    Layout = null; // Bắt buộc phải có dòng này
}

<p style="margin:10px 0 10px 0">
    Có tất cả <strong>@Model.RowCount</strong> mặt hàng trong tổng số <strong>@Model.PageCount</strong> trang.
</p>

<div class="table-responsive">
    <table class="table table-bordered table-hover table-striped">
        <thead class="table-secondary">
            <tr>
                <th style="width:80px" class="text-center">Ảnh</th>
                <th>Tên mặt hàng</th>
                <th>Đơn vị tính</th>
                <th style="width:120px" class="text-end">Giá bán</th>
                <th style="width:120px" class="text-center">Trạng thái</th>
                <th style="width:100px"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.DataItems)
            {
                <tr>
                    <td class="text-center align-middle">
                        <img src="~/images/products/@(string.IsNullOrEmpty(item.Photo) ? "nophoto.png" : item.Photo)"
                             style="width:70px; height: 70px; object-fit: cover;" class="img-thumbnail" />
                    </td>
                    <td class="align-middle">
                        <strong>@item.ProductName</strong><br />
                        <small class="text-muted">@item.ProductDescription</small>
                    </td>
                    <td class="align-middle">@item.Unit</td>
                    <td class="align-middle text-end">@item.Price.ToString("N0")</td>
                    <td class="align-middle text-center">
                        @if (item.IsSelling)
                        {
                            <span class="badge bg-success">Đang bán</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Dừng bán</span>
                        }
                    </td>
                    <td class="align-middle text-center text-nowrap">
                        <a href="~/Product/Edit/@item.ProductID" class="btn btn-sm btn-primary">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <a href="~/Product/Delete/@item.ProductID" class="btn btn-sm btn-danger">
                            <i class="bi bi-trash"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (Model.PageCount > 1)
{
    <div class="text-center mt-3">
        <ul class="pagination justify-content-center">
            @for (int p = 1; p <= Model.PageCount; p++)
            {
                if (p == Model.Page)
                {
                    <li class="page-item active"><a class="page-link" href="javascript:;">@p</a></li>
                }
                else
                {
                    <li class="page-item">
                        <a class="page-link" href="javascript:;" onclick="doSearch(@p)">@p</a>
                    </li>
                }
            }
        </ul>
    </div>
}