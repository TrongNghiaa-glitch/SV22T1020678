@model SV22T1020678.Models.Catalog.Product
@{
    Layout = null;
    var attributes = ViewBag.Attributes as IEnumerable<SV22T1020678.Models.Catalog.ProductAttribute>;
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline mt-4 shadow-sm">
            <div class="card-header">
                <div class="row align-items-center">
                    <div class="col">
                        <h6 id="attributes" class="mb-0 fw-bold">
                            <i class="bi bi-list-task me-2"></i> Thuộc tính mặt hàng
                        </h6>
                    </div>
                    <div class="col text-end">
                        <button type="button" class="btn btn-success fw-bold shadow-sm rounded-pill px-3 btn-attribute-modal" data-url="/Product/Attribute/@Model.ProductID?method=add">
                            <i class="bi bi-plus-circle me-1"></i> Bổ sung thuộc tính
                        </button>
                    </div>
                </div>
            </div>

            <div class="card-body p-1">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover mb-0">
                        <thead class="table-secondary text-center">
                            <tr>
                                <th>Tên thuộc tính</th>
                                <th>Giá trị</th>
                                <th style="width:100px">Thứ tự</th>
                                <th style="width:140px">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (attributes != null)
                            {
                                foreach (var item in attributes)
                                {
                                    <tr>
                                        <td class="align-middle">@item.AttributeName</td>
                                        <td class="align-middle">@item.AttributeValue</td>
                                        <td class="text-center align-middle">@item.DisplayOrder</td>
                                        <td class="text-center align-middle text-nowrap">
                                            <button type="button" class="btn btn-sm btn-warning shadow-sm btn-attribute-modal" data-url="/Product/Attribute/@Model.ProductID?method=edit&attributeId=@item.AttributeID" title="Cập nhật thuộc tính">
                                                <i class="bi bi-pencil-square"></i>
                                            </button>
                                            <a class="btn btn-sm btn-danger shadow-sm btn-delete-attribute" href="~/Product/Attribute/@Model.ProductID?method=delete&attributeId=@item.AttributeID" title="Xóa thuộc tính">
                                                <i class="bi bi-trash-fill"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="attributeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content" id="attributeModalContent">
        </div>
    </div>
</div>