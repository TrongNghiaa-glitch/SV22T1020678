@{
    ViewBag.Title = "Quản lý Mặt hàng";
}
@section PageToolBar {
    <a href="~/Product/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i> Bổ sung
    </a>
}
<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch" action="~/Product/Search" method="post" data-target="searchResult" onsubmit="paginationSearch(event, this, 1)">
            <div class="row g-2">
                <div class="col-md-3">
                    <label class="form-label">Loại hàng</label>
                    <select name="CategoryID" class="form-select">
                        <option value="0">-- Tất cả --</option>
                        @if (ViewBag.Categories != null)
                        {
                            foreach (var item in ViewBag.Categories)
                            {
                                if (item.CategoryID == ViewBag.CategoryID)
                                {
                                    <option value="@item.CategoryID" selected>@item.CategoryName</option>
                                }
                                else
                                {
                                    <option value="@item.CategoryID">@item.CategoryName</option>
                                }
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Nhà cung cấp</label>
                    <select name="SupplierID" class="form-select">
                        <option value="0">-- Tất cả --</option>
                        @if (ViewBag.Suppliers != null)
                        {
                            foreach (var item in ViewBag.Suppliers)
                            {
                                if (item.SupplierID == ViewBag.SupplierID)
                                {
                                    <option value="@item.SupplierID" selected>@item.SupplierName</option>
                                }
                                else
                                {
                                    <option value="@item.SupplierID">@item.SupplierName</option>
                                }
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Khoảng giá</label>
                    <div class="input-group">
                        <input type="text" name="minPrice" class="form-control number-separator" placeholder="Từ..." value="@ViewBag.MinPrice" />
                        <span class="input-group-text">-</span>
                        <input type="text" name="maxPrice" class="form-control number-separator" placeholder="Đến..." value="@ViewBag.MaxPrice" />
                    </div>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Tên mặt hàng</label>
                    <div class="input-group">
                        <input type="text" name="searchValue" class="form-control" placeholder="Nhập tên mặt hàng..." value="@ViewBag.SearchValue" autofocus />
                        <button class="btn btn-info d-flex align-items-center" type="submit">
                            <i class="bi bi-search me-1"></i> Tìm kiếm
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<div id="searchResult">
</div>

@section scripts {
    @* 1. Thư viện SweetAlert2 *@
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
            // 2. Tự động tìm kiếm khi vừa load trang (Bookmark lại đúng trang đang đứng)
            // Tận dụng hàm paginationSearch sếp đã viết ở file JS dùng chung
            paginationSearch(null, document.getElementById("formSearch"), @(ViewBag.Page ?? 1));

            // 3. Logic nổ Popup thông báo khi Thêm/Sửa/Xóa thành công
            var msg = '@Html.Raw(TempData["Message"])';

            if (msg !== '') {
                Swal.fire({
                    title: 'Thông báo',
                    text: msg,
                    icon: 'success',
                    confirmButtonColor: '#0d6efd',
                    confirmButtonText: 'Đồng ý',
                    timer: 3500, // Tự đóng sau 3.5 giây
                    showClass: {
                        popup: 'animate__animated animate__fadeInDown'
                    },
                    hideClass: {
                        popup: 'animate__animated animate__fadeOutUp'
                    }
                });
            }
        });
                // 3. CLICK VÀO NÚT THÊM / SỬA THUỘC TÍNH -> GỌI AJAX HIỆN POPUP MODAL
        $('.btn-attribute-modal').click(function (e) {
            e.preventDefault();
            var url = $(this).data('url');

            $.get(url, function (data) {
                $('#attributeModalContent').html(data);
                $('#attributeModal').modal('show');
            });
        });

        // 4. CLICK VÀO NÚT XÓA THUỘC TÍNH -> NỔ POPUP SWEETALERT2
        $('.btn-delete-attribute').click(function (e) {
            e.preventDefault();
            var url = $(this).attr('href');

            Swal.fire({
                title: '1.1.6. Xóa thuộc tính này?',
                text: "Hành động này không thể hoàn tác!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Đồng ý xóa',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = url;
                }
            });
        });
    </script>
}