@{
    ViewBag.Title = "Quản lý Đơn hàng";
}

<div class="card card-primary card-outline shadow-sm mb-3">
    <div class="card-body">
        <form id="formSearch" action="~/Order/Search" method="post" data-target="searchResult" onsubmit="paginationSearch(event, this, 1)">
            <div class="row g-2">

                <div class="col-md-3">
                    <select class="form-select" name="Status">
                        <option value="0">-- Tất cả trạng thái --</option>
                        <option value="1" selected="@(ViewBag.Status == 1)">Đơn hàng mới (Chờ duyệt)</option>
                        <option value="2" selected="@(ViewBag.Status == 2)">Đơn hàng đã duyệt (Chờ chuyển hàng)</option>
                        <option value="3" selected="@(ViewBag.Status == 3)">Đơn hàng đang được giao</option>
                        <option value="4" selected="@(ViewBag.Status == 4)">Đơn hàng đã hoàn tất</option>
                        <option value="-1" selected="@(ViewBag.Status == -1)">Đơn hàng bị hủy</option>
                        <option value="-2" selected="@(ViewBag.Status == -2)">Đơn hàng bị từ chối</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-calendar-range"></i></span>
                        <input type="text" name="TimeRange" class="form-control daterange-picker"
                               value="@ViewBag.TimeRange" placeholder="Chọn khoảng thời gian..." />
                    </div>
                </div>

                <div class="col-md-5">
                    <div class="input-group">
                        <input type="text" name="searchValue" class="form-control"
                               value="@ViewBag.SearchValue" placeholder="Nhập tên khách hàng hoặc tên người giao..." autofocus />
                        <button class="btn btn-info fw-bold" type="submit">
                            <i class="bi bi-search me-1"></i> Tìm kiếm
                        </button>
                    </div>
                </div>

            </div>
        </form>
    </div>
</div>

<div id="searchResult"></div>

@section scripts {
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/daterangepicker/daterangepicker.css" />
    <script type="text/javascript" src="https://cdn.jsdelivr.net/momentjs/latest/moment.min.js"></script>
    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/daterangepicker/daterangepicker.min.js"></script>

    <script>
        $(document).ready(function () {
            // 1. Tự động load trang 1 khi mới vào
            paginationSearch(null, document.getElementById("formSearch"), @(ViewBag.Page ?? 1));

            // 2. KHỞI TẠO LỊCH DUY NHẤT 1 LẦN (Gom chung cả format và nút chọn nhanh)
            $('.daterange-picker').daterangepicker({
                locale: {
                    format: 'DD/MM/YYYY',
                    applyLabel: 'Đồng ý',
                    cancelLabel: 'Hủy bỏ',
                    customRangeLabel: 'Tùy chọn ngày',
                    daysOfWeek: ['CN', 'T2', 'T3', 'T4', 'T5', 'T6', 'T7'],
                    monthNames: ['Tháng 1', 'Tháng 2', 'Tháng 3', 'Tháng 4', 'Tháng 5', 'Tháng 6', 'Tháng 7', 'Tháng 8', 'Tháng 9', 'Tháng 10', 'Tháng 11', 'Tháng 12'],
                    firstDay: 1
                },
                autoUpdateInput: false, // Để không tự động điền bậy bạ lúc mới load web
                ranges: {
                    'Hôm nay': [moment(), moment()],
                    'Hôm qua': [moment().subtract(1, 'days'), moment().subtract(1, 'days')],
                    '7 ngày qua': [moment().subtract(6, 'days'), moment()],
                    '30 ngày qua': [moment().subtract(29, 'days'), moment()],
                    'Tháng này': [moment().startOf('month'), moment().endOf('month')],
                    'Tháng trước': [moment().subtract(1, 'month').startOf('month'), moment().subtract(1, 'month').endOf('month')]
                }
            });

            // 3. BẮT SỰ KIỆN: Khi bấm Đồng ý hoặc chọn các nút menu bên trái
            $('.daterange-picker').on('apply.daterangepicker', function(ev, picker) {
                $(this).val(picker.startDate.format('DD/MM/YYYY') + ' - ' + picker.endDate.format('DD/MM/YYYY'));
            });

            // 4. BẮT SỰ KIỆN: Khi bấm Hủy bỏ
            $('.daterange-picker').on('cancel.daterangepicker', function(ev, picker) {
                $(this).val('');
            });
        });
    </script>
}