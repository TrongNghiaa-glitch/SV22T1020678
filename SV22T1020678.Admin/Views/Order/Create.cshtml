@model IEnumerable<SV22T1020678.Models.Sales.CartItem>
@{
    ViewBag.Title = "Lập đơn hàng";
}

<div class="row">
    <div class="col-md-4">
        <div class="card card-outline card-primary h-100">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-search"></i> Lựa chọn hàng cần bán
                </h5>
            </div>
            <div class="card-body">
                <form id="formSearchProduct" action="@Url.Action("SearchProduct", "Order")" method="get" class="mb-3">
                    <div class="mb-2">
                        <select class="form-select select2" name="categoryID">
                            <option value="0">-- Tất cả loại hàng --</option>
                            @if (ViewBag.Categories != null)
                            {
                                foreach (var item in ViewBag.Categories)
                                {
                                    <option value="@item.CategoryID">@item.CategoryName</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="input-group">
                        <input class="form-control" name="searchValue" placeholder="Nhập tên mặt hàng cần tìm" autofocus />
                        <button class="btn btn-primary" type="submit">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </form>

                <div id="searchResult">
                    <div class="text-center text-muted mt-3">
                        <div class="spinner-border text-primary mb-2" role="status"></div>
                        <p>Đang tải dữ liệu...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card card-outline card-info">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="bi bi-cart me-1"></i> Giỏ hàng của bạn
                </h5>
                @if (Model.Any())
                {
                    <form action="~/Order/ClearCart" method="post" onsubmit="return confirm('Bạn có chắc muốn xóa toàn bộ giỏ hàng?');">
                        <button type="submit" class="btn btn-sm btn-danger"><i class="bi bi-trash"></i> Xóa giỏ hàng</button>
                    </form>
                }
            </div>

            <div class="card-body p-0">
                <div id="shoppingCart" class="table-responsive">
                    <table class="table table-bordered table-hover mb-0">
                        <thead class="table-info">
                            <tr>
                                <th class="text-center" style="width:50px">STT</th>
                                <th>Tên hàng</th>
                                <th class="text-center" style="width:100px">Số lượng</th>
                                <th class="text-end" style="width:120px">Đơn giá</th>
                                <th class="text-end" style="width:120px">Thành tiền</th>
                                <th style="width:80px"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Any())
                            {
                                int i = 1;
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="text-center align-middle">@(i++)</td>
                                        <td class="align-middle">@item.ProductName</td>
                                        <td class="text-center align-middle">@item.Quantity</td>
                                        <td class="text-end align-middle">@item.SalePrice.ToString("N0")</td>
                                        <td class="text-end align-middle fw-bold">@item.TotalPrice.ToString("N0")</td>
                                        <td class="text-center align-middle text-nowrap">
                                            <a href="~/Order/EditCartItem?productId=@item.ProductID" class="btn btn-sm btn-info open-modal" title="Cập nhật số lượng/giá">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>
                                            <a href="~/Order/RemoveFromCart/@item.ProductID" class="btn btn-sm btn-danger" title="Xóa mặt hàng này">
                                                <i class="bi bi-dash"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center p-4 text-muted">
                                        Giỏ hàng đang trống. Vui lòng tìm và chọn sản phẩm để thêm vào giỏ.
                                    </td>
                                </tr>
                            }
                        </tbody>
                        @if (Model.Any())
                        {
                            <tfoot>
                                <tr class="table-light">
                                    <th colspan="4" class="text-end">Tổng cộng:</th>
                                    <th class="text-end text-danger fs-5">@Model.Sum(x => x.TotalPrice).ToString("N0")</th>
                                    <th></th>
                                </tr>
                            </tfoot>
                        }
                    </table>
                </div>
            </div>

            <div class="card-footer bg-white">
                <form action="~/Order/Init" method="post" id="formOrderInit">
                    <div class="row mb-3">
                        <label class="col-md-3 col-form-label fw-bold">Khách hàng</label>
                        <div class="col-md-9">
                            <select class="form-select select2" name="customerID" required>
                                <option value="">-- Chọn khách hàng --</option>
                                @if (ViewBag.Customers != null)
                                {
                                    foreach (var item in ViewBag.Customers)
                                    {
                                        <option value="@item.CustomerID">@item.CustomerName - @item.Phone</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-md-3 col-form-label fw-bold">Tỉnh/thành</label>
                        <div class="col-md-9">
                            <select class="form-select select2" name="deliveryProvince" required>
                                <option value="">-- Chọn tỉnh/thành giao hàng --</option>
                                @if (ViewBag.Provinces != null)
                                {
                                    foreach (var item in ViewBag.Provinces)
                                    {
                                        <option value="@item.ProvinceName">@item.ProvinceName</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-md-3 col-form-label fw-bold">Địa chỉ nhận</label>
                        <div class="col-md-9">
                            <textarea class="form-control" name="deliveryAddress" rows="2" placeholder="Nhập địa chỉ nhận hàng cụ thể" required></textarea>
                        </div>
                    </div>

                    <div class="text-end mt-3">
                        <button type="submit" id="btnSubmitOrder" class="btn btn-primary btn-lg" @(!Model.Any() ? "disabled" : "")>
                            <i class="bi bi-check-circle me-1"></i> Xác nhận lập đơn hàng
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div id="dialogModal" class="modal fade" tabindex="-1" aria-hidden="true" style="display: none; z-index: 1050;">
    <div class="modal-dialog">
        <div class="modal-content" id="dialogModalContent"></div>
    </div>
</div>

@section Scripts {
    <script>
        // 1. HÀM LOAD DANH SÁCH SẢN PHẨM BẰNG AJAX
        function doSearch(page) {
            try {
                var searchValue = $("#formSearchProduct input[name='searchValue']").val() || "";
                var categoryID = $("#formSearchProduct select[name='categoryID']").val() || 0;
                var actionUrl = $("#formSearchProduct").prop("action");

                $('#searchResult').html('<div class="text-center text-muted mt-3"><div class="spinner-border text-primary mb-2" role="status"></div><p>Đang tải dữ liệu...</p></div>');

                $.ajax({
                    url: actionUrl,
                    type: "GET",
                    data: {
                        categoryID: categoryID,
                        searchValue: searchValue,
                        page: page
                    },
                    success: function (result) {
                        if (result.includes("<html") || result.includes("<body")) {
                            $('#searchResult').html('<p class="text-danger text-center mt-3">Lỗi C#: Tham số truyền vào chưa đúng, hãy kiểm tra lại hàm SearchProduct!</p>');
                        } else {
                            $('#searchResult').html(result);
                        }
                    },
                    error: function () {
                        $('#searchResult').html('<p class="text-danger text-center mt-3">Lỗi mạng: Không thể kết nối đến máy chủ.</p>');
                    }
                });
            } catch (err) {
                console.error("Lỗi JS ở hàm doSearch: ", err);
                $('#searchResult').html('<p class="text-danger text-center mt-3">Lỗi JavaScript! Ấn F12 xem Console.</p>');
            }
        }

        // 2. HÀM KIỂM TRA FORM ĐỂ BẬT/TẮT NÚT XÁC NHẬN
        function validateOrderForm() {
            try {
                var cusId = $("select[name='customerID']").val() || "";
                var prov = ($("select[name='deliveryProvince']").val() || "").trim();
                var addr = ($("input[name='deliveryAddress']").val() || $("textarea[name='deliveryAddress']").val() || "").trim();

                var trCount = $("#shoppingCart tbody tr").length;
                var firstCellText = $("#shoppingCart tbody tr:first td").text() || "";
                var isCartEmpty = trCount === 0 || firstCellText.includes("trống");

                var btn = $("#btnSubmitOrder");
                if (btn.length > 0) {
                    if (cusId !== "" && prov !== "" && addr !== "" && !isCartEmpty) {
                        btn.prop("disabled", false);
                    } else {
                        btn.prop("disabled", true);
                    }
                }
            } catch (err) {
                console.error("Lỗi chạy kiểm tra form: ", err);
            }
        }

        // 3. KHỞI TẠO SỰ KIỆN KHI LOAD TRANG XONG
        $(document).ready(function () {

            // Khởi tạo Select2
            try {
                if (typeof $.fn.select2 !== 'undefined') {
                    $('.select2').select2({ width: '100%' });
                }
            } catch (err) {
                console.error("Lỗi Select2: ", err);
            }

            // Gắn sự kiện Tìm kiếm
            $('#formSearchProduct').submit(function (e) {
                e.preventDefault();
                doSearch(1);
            });

            // Tự động tìm kiếm khi đổi Loại hàng
            $("#formSearchProduct select[name='categoryID']").on("change", function () {
                doSearch(1);
            });

            // Gọi tìm kiếm lần đầu
            doSearch(1);

            // Gắn sự kiện Validate form (Tỉnh/thành, Khách hàng, Địa chỉ)
            validateOrderForm();
            $("select[name='customerID'], select[name='deliveryProvince'], input[name='deliveryAddress'], textarea[name='deliveryAddress']").on("input change", function () {
                validateOrderForm();
            });
            $("select[name='customerID'], select[name='deliveryProvince']").on("select2:select select2:unselect", function () {
                validateOrderForm();
            });

            // Sự kiện: Thêm vào giỏ hàng
            $(document).on("submit", ".formAddToCart", function (e) {
                e.preventDefault();
                var form = $(this);
                $.ajax({
                    url: form.prop("action"),
                    type: form.prop("method"),
                    data: form.serialize(),
                    success: function (result) {
                        var newCartTable = $(result).find("#shoppingCart").html();
                        if (newCartTable) {
                            $("#shoppingCart").html(newCartTable);
                            validateOrderForm(); // Check lại nút xác nhận
                        } else {
                            window.location.reload();
                        }
                    },
                    error: function () { alert("Lỗi: Không thể thêm mặt hàng vào giỏ!"); }
                });
            });

            // Sự kiện: Chốt Lập đơn hàng
            $("#formOrderInit").submit(function (e) {
                e.preventDefault();
                if ($("#btnSubmitOrder").is(":disabled")) return false;

                $.ajax({
                    url: $(this).prop("action"),
                    type: $(this).prop("method"),
                    data: $(this).serialize(),
                    success: function (result) {
                        if (result.success) {
                            window.location.href = "/Order/Detail/" + result.orderID;
                        } else {
                            alert(result.message);
                        }
                    },
                    error: function () { alert("Lỗi hệ thống khi kết nối đến máy chủ!"); }
                });
            });

            // Sự kiện: Mở popup sửa số lượng trong giỏ
            $(document).on("click", ".open-modal", function (e) {
                e.preventDefault();
                $.ajax({
                    url: $(this).attr("href"),
                    type: "GET",
                    success: function (data) {
                        $("#dialogModalContent").html(data);
                        $("#dialogModal").modal("show");
                    },
                    error: function () { alert("Không thể tải giao diện cập nhật mặt hàng!"); }
                });
            });

        });
    </script>
}